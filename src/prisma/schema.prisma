generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  language    String
  icon        String
  color       String
  description String
  lessons     Lesson[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Lesson {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int    @default(0)
  slides   Slide[]
}

model Slide {
  id       String @id @default(uuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title    String
  content  String
  code     String @default("")
  language String @default("")
  order    Int    @default(0)
}

model Cheatsheet {
  id          String @id @default(uuid())
  language    String
  category    String
  title       String
  code        String
  description String
  order       Int    @default(0)
}

model ContactSubmission {
  id          String   @id @default(uuid())
  projectType String
  budget      String
  timeline    String
  stack       String
  name        String
  email       String
  company     String   @default("")
  message     String
  createdAt   DateTime @default(now())
}
